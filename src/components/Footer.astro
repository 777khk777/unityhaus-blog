---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<span>&copy; {today.getFullYear()} UnityHaus. All rights reserved.</span>
		<div class="footer-links">
			<a href="https://unityhaus.ca" target="_blank">Main site</a>
			<a href="https://www.youtube.com/@Unityhaus-Canada/videos" target="_blank">YouTube</a>
			<a href="/rss.xml">RSS feed</a>
		</div>
	</div>
</footer>

<style>
	footer {
		background: #141412;
		padding: 1.5rem 2rem;
		margin-top: 4rem;
	}
	.footer-inner {
		max-width: 900px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: 1rem;
		font-size: 14px;
		color: #555;
	}
	.footer-links {
		display: flex;
		gap: 1.5rem;
	}
	.footer-links a {
		color: #555;
		text-decoration: none;
		transition: color 0.15s;
	}
	.footer-links a:hover { color: #888; }
</style>
