---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`All Posts — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>All Posts</h1>
			<section class="posts">
				{posts.map((post) => (
					<a class="post-card" href={`/blog/${post.id}/`}>
						<div class="post-meta">
							<FormattedDate date={post.data.pubDate} />
						</div>
						<h2 class="post-title">{post.data.title}</h2>
						{post.data.description && <p class="post-desc">{post.data.description}</p>}
					</a>
				))}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	h1 {
		margin-bottom: 2rem;
	}
	.posts {
		display: flex;
		flex-direction: column;
		gap: 1px;
	}
	.post-card {
		display: block;
		padding: 1.5rem 0;
		border-bottom: 1px solid var(--cream-border);
		text-decoration: none;
	}
	.post-card:hover .post-title { color: var(--green); }
	.post-meta {
		font-size: 13px;
		color: #999;
		margin-bottom: 0.3rem;
	}
	.post-title {
		font-family: var(--font-serif);
		font-size: 1.25rem;
		color: var(--black);
		font-weight: 400;
		margin-bottom: 0.3rem;
		transition: color 0.15s;
	}
	.post-desc {
		font-size: 15px;
		color: var(--stone);
		margin: 0;
	}
</style>
