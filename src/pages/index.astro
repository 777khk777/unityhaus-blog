---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div class="hero-block">
				<div class="eyebrow">Build journal</div>
				<h1>Oshawa ADU —<br/>Passive House from the ground up</h1>
				<p class="hero-sub">Documenting the construction of a Passive House accessory dwelling unit in Oshawa, Ontario. From design and permitting to the final blower-door test — all in public.</p>
			</div>

			<section class="posts">
				{posts.map((post) => (
					<a class="post-card" href={`/blog/${post.id}/`}>
						<div class="post-meta">
							<FormattedDate date={post.data.pubDate} />
						</div>
						<h2 class="post-title">{post.data.title}</h2>
						{post.data.description && <p class="post-desc">{post.data.description}</p>}
					</a>
				))}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero-block {
		border-bottom: 1px solid var(--cream-border);
		padding-bottom: 2.5rem;
		margin-bottom: 2.5rem;
	}
	.eyebrow {
		font-size: 12px;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--green);
		margin-bottom: 0.6rem;
	}
	h1 {
		color: var(--black);
		margin-bottom: 0.75rem;
	}
	.hero-sub {
		font-size: 16px;
		color: var(--stone);
		max-width: 540px;
		margin-bottom: 0;
	}
	.posts {
		display: flex;
		flex-direction: column;
		gap: 1px;
	}
	.post-card {
		display: block;
		padding: 1.5rem 0;
		border-bottom: 1px solid var(--cream-border);
		text-decoration: none;
		transition: background 0.15s;
	}
	.post-card:hover .post-title { color: var(--green); }
	.post-meta {
		font-size: 13px;
		color: #999;
		margin-bottom: 0.3rem;
	}
	.post-title {
		font-family: var(--font-serif);
		font-size: 1.25rem;
		color: var(--black);
		font-weight: 400;
		margin-bottom: 0.3rem;
		transition: color 0.15s;
	}
	.post-desc {
		font-size: 15px;
		color: var(--stone);
		margin: 0;
	}
</style>
